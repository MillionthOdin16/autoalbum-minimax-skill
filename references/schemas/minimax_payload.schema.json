{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MiniMaxDirectPayload",
  "type": "object",
  "required": [
    "model",
    "prompt",
    "lyrics_optimizer",
    "is_instrumental",
    "audio_setting"
  ],
  "properties": {
    "model": {
      "type": "string"
    },
    "prompt": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "lyrics": {
      "type": "string",
      "maxLength": 3500
    },
    "lyrics_optimizer": {
      "type": "boolean"
    },
    "is_instrumental": {
      "type": "boolean"
    },
    "stream": {
      "type": "boolean"
    },
    "output_format": {
      "enum": [
        "url",
        "hex"
      ]
    },
    "audio_setting": {
      "type": "object",
      "required": [
        "sample_rate",
        "bitrate",
        "format"
      ],
      "properties": {
        "sample_rate": {
          "type": "integer"
        },
        "bitrate": {
          "type": "integer"
        },
        "format": {
          "type": "string"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {
          "is_instrumental": {
            "const": false
          },
          "lyrics_optimizer": {
            "const": false
          }
        }
      },
      "then": {
        "required": [
          "lyrics"
        ],
        "properties": {
          "lyrics": {
            "minLength": 1
          }
        }
      }
    }
  ]
}