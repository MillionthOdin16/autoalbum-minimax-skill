{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "HookLab",
  "type": "object",
  "required": ["track_number", "candidates", "selected_hook", "backup_hook", "pass"],
  "properties": {
    "track_number": {"type": "integer"},
    "track_title": {"type": "string"},
    "candidates": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["phrase", "hook_type", "chorus_nucleus", "scores", "decision"],
        "properties": {
          "phrase": {"type": "string"},
          "hook_type": {"type": "string"},
          "delivery_note": {"type": "string"},
          "chorus_nucleus": {"type": "string"},
          "scores": {
            "type": "object",
            "required": ["memorability", "singability_rapability", "style_fit", "album_fit", "novelty", "minimax_render_likelihood"],
            "properties": {
              "memorability": {"type": "number"},
              "singability_rapability": {"type": "number"},
              "style_fit": {"type": "number"},
              "album_fit": {"type": "number"},
              "novelty": {"type": "number"},
              "minimax_render_likelihood": {"type": "number"}
            }
          },
          "decision": {"type": "string"},
          "rationale": {"type": "string"}
        }
      }
    },
    "selected_hook": {"type": "string"},
    "backup_hook": {"type": "string"},
    "revisions_required": {"type": "array", "items": {"type": "string"}},
    "pass": {"type": "boolean"}
  }
}
